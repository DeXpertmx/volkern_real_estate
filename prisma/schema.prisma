generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Property {
  id          String   @id @default(uuid())
  title       String
  price       Decimal  @db.Decimal(10, 2)
  location    String
  city        String
  country     String
  type        String   // casa, apartamento, terreno, comercial
  bedrooms    Int
  bathrooms   Int
  area        Int
  parking     Int      @default(0)
  operation   String   @default("venta") // venta, renta
  description String?  @db.Text
  images      String[]
  featured    Boolean  @default(false)
  volkernId   String?  @unique // ID en el Volkern CRM para sincronización
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  role      String   @default("USER") // ADMIN, USER, AGENT
  createdAt DateTime @default(now())
}
